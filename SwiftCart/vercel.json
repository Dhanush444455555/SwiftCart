{
  "version": 2,
  "builds": [
    {
      "src": "01_frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "03_ai_model/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/offers/(.*)",
      "dest": "/03_ai_model/server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/01_frontend/dist/index.html"
    }
  ]
}
